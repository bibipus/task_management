<div class="row">
  <div class="col-12 hero">
    <h1><%= t('.edit_account') %></h1>
  </div>

  <div class="card mt-4 card-body">
    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>

      <div class="form-group">
        <%= f.input :email, label: t('.email'), input_html: { autofocus: true } %>
      </div>

      <div class="form-group">
        <%= f.input :first_name, label: t('.first_name') %>
      </div>

      <div class="form-group">
        <%= f.input :last_name, label: t('.last_name') %>
      </div>

      <div class="form-group">
        <%= f.input :password, label: "#{t('.password')} (#{t('.optional')})", input_html: { autocomplete: 'off' } %>
      </div>

      <div class="form-group">
        <%= f.input :password_confirmation, label: t('.password_confirmation'), input_html: { autocomplete: 'off' } %>
      </div>

      <div class="form-group">
        <%= f.input :current_password, label: t('.current_password'), input_html: { autocomplete: 'off' } %>
      </div>

      <div class="actions">
        <%= f.button :submit, t('.update'), class: "btn btn-primary float-end" %>
      </div>
    <% end %>
  </div>

  <div class="card mt-4 card-body">
    <h3 class="text-danger"><%= t('.danger_zone') %></h3>
    <p><%= t('.cancel_account_description') %></p>
    <%= link_to t('.cancel_account'), registration_path(:user),
                data: { turbo_method: :delete, turbo_confirm: t('.confirm_cancel') },
                class: "btn btn-danger" %>
  </div>
</div>