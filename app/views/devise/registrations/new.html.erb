<h2>Registrace</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <div><%= f.label :email, "Email" %><br/>
    <%= f.email_field :email, autofocus: true, autocomplete: "email" %></div>

  <div><%= f.label :first_name, "Křestní jméno" %><br/>
    <%= f.text_field :first_name %></div>

  <div><%= f.label :last_name, "Příjmení" %><br/>
    <%= f.text_field :last_name %></div>

  <div><%= f.label :password, "Heslo" %>
    <% if @minimum_password_length %>
      <em>(minimálně <%= @minimum_password_length %> znaků)</em>
    <% end %><br/>
    <%= f.password_field :password, autocomplete: "new-password" %></div>

  <div><%= f.label :password_confirmation, "Potvrzení hesla" %><br/>
    <%= f.password_field :password_confirmation, autocomplete: "new-password" %></div>

  <div><%= f.submit "Zaregistrovat se" %></div>
<% end %>